#!/bin/sh
# S99prady — Prady OS Service Init Script
# Phase 33: Production ISO Build
#
# Starts Docker, all Prady OS services via docker compose,
# and launches Chromium in kiosk mode pointing to the desktop shell.
#
# Placement: /etc/init.d/S99prady (sysvinit / busybox init style)
# For systemd systems, see /etc/systemd/system/prady.service

set -e

COMPOSE_FILE="/etc/prady/docker-compose.prod.yml"
DISPLAY_NUM=":0"
DESKTOP_URL="http://localhost:3000"
CHROMIUM_BIN="chromium-browser"
XORG_DISPLAY_TTY="vt1"
LOG_FILE="/var/log/prady-init.log"

# Fallback chromium binary names (distro-specific)
for bin in chromium-browser chromium google-chrome-stable google-chrome; do
    if command -v "${bin}" >/dev/null 2>&1; then
        CHROMIUM_BIN="${bin}"
        break
    fi
done

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "${LOG_FILE}"
}

start() {
    log "Prady OS: Starting (S99prady start)"

    # ──────────────────────────────────────────────────────
    # Start Xorg on tty1
    # ──────────────────────────────────────────────────────
    if [ -z "${DISPLAY:-}" ]; then
        log "Prady OS: Starting Xorg on ${DISPLAY_NUM} (${XORG_DISPLAY_TTY})"
        export DISPLAY="${DISPLAY_NUM}"
        xinit /etc/prady/xinitrc -- "${DISPLAY_NUM}" "${XORG_DISPLAY_TTY}" &
        sleep 2
    else
        log "Prady OS: Display already set to ${DISPLAY}"
        export DISPLAY="${DISPLAY}"
    fi

    # ──────────────────────────────────────────────────────
    # Wait for Docker daemon
    # ──────────────────────────────────────────────────────
    log "Prady OS: Waiting for Docker daemon..."
    timeout=120
    while ! docker info >/dev/null 2>&1; do
        timeout=$((timeout - 1))
        if [ "${timeout}" -le 0 ]; then
            log "Prady OS: ERROR — Docker daemon did not start within 120 seconds"
            log "Prady OS: Check 'journalctl -u docker' for details"
            exit 1
        fi
        sleep 1
    done
    log "Prady OS: Docker daemon ready"

    # ──────────────────────────────────────────────────────
    # Start all services via docker compose
    # ──────────────────────────────────────────────────────
    if [ ! -f "${COMPOSE_FILE}" ]; then
        log "Prady OS: ERROR — Compose file not found: ${COMPOSE_FILE}"
        exit 1
    fi

    log "Prady OS: Starting services from ${COMPOSE_FILE}"
    docker compose -f "${COMPOSE_FILE}" up -d
    log "Prady OS: All services started"

    # ──────────────────────────────────────────────────────
    # Wait for desktop shell to be reachable on port 3000
    # ──────────────────────────────────────────────────────
    log "Prady OS: Waiting for desktop shell at ${DESKTOP_URL}..."
    timeout=120
    while ! curl -sf "${DESKTOP_URL}" >/dev/null 2>&1; do
        timeout=$((timeout - 1))
        if [ "${timeout}" -le 0 ]; then
            log "Prady OS: WARNING — Desktop shell not ready; launching Chromium anyway"
            break
        fi
        sleep 1
    done

    # ──────────────────────────────────────────────────────
    # Launch Chromium in kiosk mode
    # ──────────────────────────────────────────────────────
    log "Prady OS: Launching ${CHROMIUM_BIN} kiosk at ${DESKTOP_URL}"
    export DISPLAY="${DISPLAY_NUM}"

    "${CHROMIUM_BIN}" \
        --kiosk \
        --no-sandbox \
        --disable-infobars \
        --disable-session-crashed-bubble \
        --disable-restore-session-state \
        --disable-component-update \
        --autoplay-policy=no-user-gesture-required \
        --start-fullscreen \
        --window-position=0,0 \
        --app="${DESKTOP_URL}" &

    log "Prady OS: Startup complete — Prady OS is running"
}

stop() {
    log "Prady OS: Stopping services (S99prady stop)"
    docker compose -f "${COMPOSE_FILE}" down --timeout 30
    log "Prady OS: All services stopped"
}

restart() {
    stop
    sleep 2
    start
}

status() {
    echo "=== Prady OS Service Status ==="
    docker compose -f "${COMPOSE_FILE}" ps
}

case "$1" in
    start)   start   ;;
    stop)    stop    ;;
    restart) restart ;;
    status)  status  ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit 0
