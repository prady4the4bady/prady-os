[Unit]
Description=Prady Wayland MCP Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/prady/platform/wayland-mcp
ExecStart=/usr/local/bin/uvicorn wayland_mcp:app --host 0.0.0.0 --port 8103
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
