[Unit]
Description=Prady Memory Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/prady/platform/memory-service
ExecStart=/usr/local/bin/uvicorn memory_service:app --host 0.0.0.0 --port 8108
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
