#
# Lumyn sandbox base image — expensive, rarely-changing layers.
#
# Contains: node:22-slim (OpenShell needs Node), apt packages, gosu,
# user/group setup, .lumyn directory structure, Lumyn CLI, and the
# dependencies for Vyrex-supported Lumyn integrations.
#
# Mirrors the OpenClaw Dockerfile.base structure but installs Lumyn
# (Python-based) instead of OpenClaw (Node-based).
#
# ── When to rebuild ─────────────────────────────────────────────
#   1. Lumyn version bump      — change the LUMYN_VERSION below
#   2. New apt package needed   — add it to the apt-get install list
#   3. gosu upgrade             — update URL, checksum, and version
#   4. node:22-slim digest rot  — update-docker-pin.sh updates both
#   5. New .lumyn subdirectory — add mkdir below
# ────────────────────────────────────────────────────────────────

FROM node:22-slim@sha256:4f77a690f2f8946ab16fe1e791a3ac0667ae1c3575c3e4d0d4589e9ed5bfaf3d

ENV DEBIAN_FRONTEND=noninteractive

# Lumyn version pinned for reproducibility.
# Calver tag v2026.4.23 = semver 0.11.0.
ARG LUMYN_VERSION=v2026.4.23
ARG LUMYN_TARBALL_SHA256=1ee1be80a2112b7edc581770cee8858e725ba110cc423979cd7102492504bc6b
ARG LUMYN_UV_EXTRAS="messaging web"
ARG UV_VERSION=0.11.8

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3=3.11.2-1+b1 \
        python3-pip=23.0.1+dfsg-1 \
        python3-venv=3.11.2-1+b1 \
        curl=7.88.1-10+deb12u14 \
        git=1:2.39.5-0+deb12u3 \
        ca-certificates=20230311+deb12u1 \
        iproute2=6.1.0-3 \
        iptables=1.8.9-2 \
        libcap2-bin=1:2.66-4+deb12u2+b2 \
        socat=1.7.4.4-2 \
    && rm -rf /var/lib/apt/lists/*

# gosu for privilege separation (gateway vs sandbox user).
# Identical to OpenClaw base — pinned to 1.19 with checksum.
# hadolint ignore=DL4006
RUN arch="$(dpkg --print-architecture)" \
    && case "$arch" in \
        amd64) gosu_asset="gosu-amd64"; gosu_sha256="52c8749d0142edd234e9d6bd5237dff2d81e71f43537e2f4f66f75dd4b243dd0" ;; \
        arm64) gosu_asset="gosu-arm64"; gosu_sha256="3a8ef022d82c0bc4a98bcb144e77da714c25fcfa64dccc57f6aba7ae47ff1a44" ;; \
        *) echo "Unsupported architecture for gosu: $arch" >&2; exit 1 ;; \
    esac \
    && curl -fsSL -o /usr/local/bin/gosu "https://github.com/tianon/gosu/releases/download/1.19/${gosu_asset}" \
    && echo "${gosu_sha256}  /usr/local/bin/gosu" | sha256sum -c - \
    && chmod +x /usr/local/bin/gosu \
    && gosu --version

# Create sandbox user (matches OpenShell convention) and gateway user.
# gateway is a member of the sandbox group so it can read Lumyn config files
# and write Lumyn runtime state while config files remain non-group-writable.
RUN groupadd -r sandbox \
    && groupadd -r gateway \
    && useradd -r -g gateway -G sandbox -d /sandbox -s /usr/sbin/nologin gateway \
    && useradd -r -g sandbox -d /sandbox -s /bin/bash sandbox \
    && usermod -a -G sandbox root \
    && mkdir -p /sandbox/.vyrex \
    && chown -R sandbox:sandbox /sandbox

# Create .lumyn with mutable integration dirs plus a scoped runtime dir.
# Top-level gateway state names redirect into runtime so the config root can
# remain non-group-writable without reintroducing the old .lumyn-data bridge.
RUN mkdir -p /sandbox/.lumyn/memories \
        /sandbox/.lumyn/sessions \
        /sandbox/.lumyn/skills \
        /sandbox/.lumyn/plugins \
        /sandbox/.lumyn/cron \
        /sandbox/.lumyn/logs \
        /sandbox/.lumyn/skins \
        /sandbox/.lumyn/plans \
        /sandbox/.lumyn/workspace \
        /sandbox/.lumyn/profiles \
        /sandbox/.lumyn/cache \
        /sandbox/.lumyn/pairing \
        /sandbox/.lumyn/runtime \
    && chown -R sandbox:sandbox /sandbox/.lumyn \
    && chown gateway:sandbox /sandbox/.lumyn/runtime \
    && chmod 750 /sandbox/.lumyn \
    && chmod 770 \
        /sandbox/.lumyn/memories \
        /sandbox/.lumyn/sessions \
        /sandbox/.lumyn/skills \
        /sandbox/.lumyn/plugins \
        /sandbox/.lumyn/cron \
        /sandbox/.lumyn/logs \
        /sandbox/.lumyn/skins \
        /sandbox/.lumyn/plans \
        /sandbox/.lumyn/workspace \
        /sandbox/.lumyn/profiles \
        /sandbox/.lumyn/cache \
        /sandbox/.lumyn/pairing \
        /sandbox/.lumyn/runtime \
    && for name in state.db state.db-wal state.db-shm gateway.pid gateway.lock gateway_state.json channel_directory.json; do \
        rm -f "/sandbox/.lumyn/${name}"; \
        ln -s "runtime/${name}" "/sandbox/.lumyn/${name}"; \
    done

# Pre-create shell init files for the sandbox user.
# The /sandbox home directory is Landlock read-only at runtime (#804), so these
# files must exist at build time. The Lumyn entrypoint writes proxy vars and
# LUMYN_HOME to /tmp/vyrex-proxy-env.sh (root-owned, mode 444); these rc
# files source it on every interactive `openshell sandbox connect` session.
# Ref: #2376.
# hadolint ignore=SC2016,SC2028
RUN printf '%s\n' \
        '# Source runtime proxy + LUMYN_HOME config (Landlock read-only home, #804)' \
        '[ -f /tmp/vyrex-proxy-env.sh ] && . /tmp/vyrex-proxy-env.sh' \
        'export PATH="/usr/local/bin:/opt/lumyn/.venv/bin:${PATH}"' \
        > /sandbox/.bashrc \
    && printf '%s\n' \
        '# Source runtime proxy + LUMYN_HOME config (Landlock read-only home, #804)' \
        '[ -f /tmp/vyrex-proxy-env.sh ] && . /tmp/vyrex-proxy-env.sh' \
        'export PATH="/usr/local/bin:/opt/lumyn/.venv/bin:${PATH}"' \
        > /sandbox/.profile \
    && chown root:root /sandbox/.bashrc /sandbox/.profile \
    && chmod 444 /sandbox/.bashrc /sandbox/.profile

# Install Lumyn from the selected GitHub release.
# The image prebakes only the extras mapped to Vyrex-supported onboarding
# integrations: messaging (Telegram, Discord, Slack) and web (API health/UI
# runtime). New Lumyn integrations should be installed by the agent workflow
# when they are enabled rather than shipped in the base image by default.
RUN pip3 install --no-cache-dir --break-system-packages "uv==${UV_VERSION}"
RUN mkdir -p /opt/lumyn \
    && curl -fsSL "https://github.com/NousResearch/lumyn/archive/refs/tags/${LUMYN_VERSION}.tar.gz" -o /tmp/lumyn.tar.gz \
    && printf '%s  /tmp/lumyn.tar.gz\n' "${LUMYN_TARBALL_SHA256}" > /tmp/lumyn.tar.gz.sha256 \
    && sha256sum -c /tmp/lumyn.tar.gz.sha256 \
    && tar -xzf /tmp/lumyn.tar.gz -C /opt/lumyn --strip-components=1 \
    && rm /tmp/lumyn.tar.gz /tmp/lumyn.tar.gz.sha256
WORKDIR /opt/lumyn
# hadolint ignore=SC2086
RUN set -eu; \
    set --; \
    for extra in ${LUMYN_UV_EXTRAS}; do \
        set -- "$@" --extra "$extra"; \
    done; \
    uv sync --frozen --no-dev "$@" --no-cache \
    && ln -sf /opt/lumyn/.venv/bin/lumyn /usr/local/bin/lumyn \
    && ln -sf /opt/lumyn/.venv/bin/lumyn /usr/local/bin/lumyn \
    && ln -sf /opt/lumyn/.venv/bin/lumyn-acp /usr/local/bin/lumyn-acp

ENV PATH="/usr/local/bin:/opt/lumyn/.venv/bin:${PATH}"
RUN /usr/local/bin/lumyn --version
