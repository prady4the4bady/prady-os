# Force LF line endings on all shell scripts and Linux config files.
# Without this, Windows checkouts would convert to CRLF on disk and the
# Buildroot ISO build would fail with "syntax error near unexpected token"
# because /bin/bash sees `do\r` instead of `do`.
*.sh           text eol=lf
*.bash         text eol=lf
Makefile       text eol=lf
*.mk           text eol=lf
*.py           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.toml         text eol=lf
*.cfg          text eol=lf
*.ini          text eol=lf
*.service      text eol=lf
*.target       text eol=lf
*.timer        text eol=lf
*defconfig*    text eol=lf
grub.cfg       text eol=lf
/build/iso/buildroot-config/** text eol=lf
/build/iso/rootfs_overlay/**   text eol=lf
/build/iso/scripts/**          text eol=lf

# Binary blobs that should never be touched.
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.ico          binary
*.iso          binary
*.gz           binary
*.xz           binary
*.zst          binary
*.tar          binary
*.zip          binary
*.woff         binary
*.woff2        binary
*.db           binary
*.sqlite       binary
*.sqlite3      binary
