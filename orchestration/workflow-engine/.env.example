# Prady Orchestration Engine — environment variables

# Redis (required)
REDIS_URL=redis://localhost:6379

# Phase 1 model-gateway (required)
MODEL_GATEWAY_URL=http://localhost:11430

# Phase 3 playwright-runner (required for real browser actions)
PLAYWRIGHT_RUNNER_URL=http://localhost:11432

# Model to use for final summarisation
GATEWAY_MODEL=llama3.2:3b

# Primary planner model used by conductor._decompose (Lumyn via model-gateway)
PLANNER_MODEL=lumyn

# Screen agent backend selection: auto | ydotool | xdotool | pyautogui
SCREEN_BACKEND=auto

# Enable OCR support in screen agent
SCREEN_OCR_ENABLED=true

# Directory where screen agent stores screenshots
SCREEN_SCREENSHOT_DIR=/tmp/prady-screenshots

# System dependencies required by screen agent:
#   ydotool, xdotool, grim, scrot, tesseract-ocr

# Directory for activity.jsonl
ACTIVITY_LOG_DIR=./logs

# Seconds to wait for a human approval before timing out
APPROVAL_TIMEOUT_SECONDS=300
